@startuml sequence_UC-05_virement_externe
title UC-05 : Virement externe (clients différents) avec AML

hide footbox

actor Client
participant "Kong" as Kong
participant "nginx" as LB
participant "PaymentService" as PS
participant "AccountService" as AS
database "postgres-payment" as PayDB
database "postgres-account" as AccDB
database "Redis" as Redis

Client -> Kong : POST /api/v1/virements\n{ CompteSourceId, CompteDestinataireId, Montant }\nAuthorization: Bearer JWT
Kong -> LB : HTTP
LB -> PS : POST /api/v1/virements

PS -> Redis : StringGetAsync(idempotency:{key})

PS -> AS : GET /internal/comptes/{CompteSourceId}
AS -> AccDB : GetByIdAsync(CompteSourceId)
AS --> PS : { Solde, ClientId }

PS -> AS : GET /internal/comptes/{CompteDestinataireId}
AS -> AccDB : GetByIdAsync(CompteDestinataireId)
AS --> PS : { Solde, ClientId }

note over PS : ClientId source != ClientId dest\n→ virement externe, vérification AML requise

alt Solde insuffisant
  PS --> Client : 400 Bad Request\n{ error: "Fonds insuffisants sur le compte source." }
else Solde suffisant
  PS -> PS : AML — montant > 10 000 CAD\nou montant / solde > 60%

  PS -> AS : DebitAsync(CompteSourceId, montant)
  AS -> AccDB : UpdateAsync(compte)
  AS -> Redis : KeyDeleteAsync(comptes:{clientId})
  AS --> PS : 200 OK { Solde }

  PS -> AS : CreditAsync(CompteDestinataireId, montant)
  AS -> AccDB : UpdateAsync(compte)
  AS -> Redis : KeyDeleteAsync(comptes:{clientId})
  AS --> PS : 200 OK { Solde }

  alt AML suspect
    PS -> PayDB : CreateAsync(virement)\n(Statut = Suspect)
    PS -> Redis : StringSetAsync(idempotency:{key}, TTL 24h)
    PS -> PayDB : AuditLogs.AddAsync(VIREMENT_SUSPECT)
    PS --> Client : 200 OK\n{ VirementId, Montant, Statut: Suspect }
  else AML OK
    PS -> PayDB : CreateAsync(virement)\n(Statut = Effectué)
    PS -> Redis : StringSetAsync(idempotency:{key}, TTL 24h)
    PS -> PayDB : AuditLogs.AddAsync(VIREMENT_EFFECTUÉ)
    PS --> Client : 200 OK\n{ VirementId, Montant, Statut: Effectué }
  end
end

@enduml
